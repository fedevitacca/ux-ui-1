---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Section from '../components/Section.astro';
import PlayerGrid from '../components/PlayerGrid.astro';

const BUCKS_ID = 17;
const SEASON = 2025; // 2025-26 season start year
const API_KEY = import.meta.env.BALLDONTLIE_API_KEY;
const API_BASE = API_KEY ? 'https://api.balldontlie.io/v1' : 'https://www.balldontlie.io/api/v1';
const authHeaders = API_KEY ? { Authorization: `Bearer ${API_KEY}` } : {};

const fallbackPlayers = [
	{
		name: 'Alex Antetokounmpo',
		position: 'F',
		heightCm: 203,
		weightKg: 97,
		number: 29,
		college: '--',
		bio: 'Ala fisico, corta sin pelota y corre la cancha.'
	},
	{
		name: 'Giannis Antetokounmpo',
		position: 'F',
		heightCm: 211,
		weightKg: 110,
		number: 34,
		college: '--',
		bio: 'MVP, motor de transicion y ancla defensiva.'
	},
	{
		name: 'Thanasis Antetokounmpo',
		position: 'F',
		heightCm: 201,
		weightKg: 99,
