---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SectionNavigator from '../components/SectionNavigator.astro';
import { getBucksData } from '../data/bucks';

const { players, schedule, highlights } = await getBucksData();
const baseUrl = import.meta.env.BASE_URL;

const navItems = [
	{
		href: `${baseUrl}snapshot/`,
		label: 'Snapshot',
		eyebrow: 'Radiografia',
		description: 'Estado de la temporada, lectura del momento Bucks y resumen rapido del contexto competitivo.',
		meta: 'Resumen ejecutivo',
		accent: 'green'
	},
	{
		href: `${baseUrl}roster/`,
		label: 'Roster',
		eyebrow: 'Plantel',
		description: 'Todos los jugadores en una pagina dedicada con filtros, datos fisicos, edad y salario.',
		meta: `${players.length} jugadores`,
		accent: 'blue'
	},
	{
		href: `${baseUrl}schedule/`,
		label: 'Calendario',
		eyebrow: 'Partidos',
		description: 'Proximos juegos desde el 15 de marzo con contexto util para presentar cada cruce.',
		meta: `${schedule.length} juegos`,
		accent: 'gold'
	},
	{
		href: `${baseUrl}identity/`,
		label: 'Identidad',
		eyebrow: 'Narrativa',
		description: 'Caracteristicas tacticas y visuales para darle tono al proyecto y defender la propuesta.',
		meta: `${highlights.length} ejes`,
		accent: 'dark'
	}
];
---

<Layout
	title="Milwaukee Bucks | Portal 25-26"
	description="Portada del catalogo 25-26 de los Milwaukee Bucks con accesos grandes a cada vista."
>
	<Navbar />
	<main class="landing">
		<section class="intro">
			<p class="eyebrow">Milwaukee Bucks</p>
			<h1>Elegi una vista y entra a una pantalla dedicada.</h1>
			<p class="lead">
				La home ahora funciona como portal. Cada card ocupa casi toda la pantalla y abre una ruta
				distinta con la informacion desarrollada.
			</p>
		</section>

		<SectionNavigator items={navItems} />
	</main>
</Layout>

<style>
	.landing {
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 1rem;
		min-height: calc(100vh - 72px);
	}

	.intro {
		max-width: 1180px;
		margin: 0 auto;
		padding: 1.4rem 1.25rem 0;
		width: 100%;
	}

	.eyebrow {
		margin: 0 0 0.35rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--brand);
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 6vw, 4.25rem);
		line-height: 0.95;
		letter-spacing: -0.05em;
		max-width: 12ch;
	}

	.lead {
		max-width: 56ch;
		margin: 0.85rem 0 0;
	}

	@media (max-width: 720px) {
		.landing {
			min-height: auto;
		}

		.intro {
			padding-inline: 1rem;
		}
	}
</style>
