		bio: 'Mano caliente, especialista catch-and-shoot.'
	},
	{
		name: 'Gary Harris',
		position: 'G',
		heightCm: 193,
		weightKg: 95,
		number: 11,
		college: 'Michigan State',
		bio: 'Veterano 3&D, corta linea de pase.'
	},
	{
		name: 'Andre Jackson Jr.',
		position: 'G',
		heightCm: 198,
		weightKg: 95,
		number: 44,
		college: 'UConn',
		bio: 'Playmaker secundario, defiende multiples posiciones.'
	},
	{
		name: 'Kyle Kuzma',
		position: 'F',
		heightCm: 203,
		weightKg: 100,
		number: 18,
		college: 'Utah',
		bio: 'Ala anotador, ataca closeouts y post alto.'
	},
	{
		name: 'Pete Nance',
		position: 'F',
		heightCm: 206,
		weightKg: 102,
		number: 35,
		college: 'North Carolina',
		bio: 'Stretch four con lectura de pase extra.'
	},
	{
		name: 'Kevin Porter Jr.',
		position: 'G',
		heightCm: 196,
		weightKg: 92,
		number: 7,
		college: 'USC',
		bio: 'Shot-creator con stepback y pick-and-roll.'
	},
	{
		name: 'Bobby Portis',
		position: 'F/C',
		heightCm: 206,
		weightKg: 113,
		number: 9,
		college: 'Arkansas',
