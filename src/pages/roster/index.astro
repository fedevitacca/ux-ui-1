---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import PlayerGrid from '../../components/PlayerGrid.astro';
import { getBucksData } from '../../data/bucks';

const { players, positions } = await getBucksData();
const baseUrl = import.meta.env.BASE_URL;
---

<Layout
	title="Milwaukee Bucks | Roster"
	description="Plantel 25-26 de los Milwaukee Bucks con filtros, datos fisicos y perfiles."
>
	<Navbar />
	<main class="page">
		<section class="hero">
			<div>
				<p class="eyebrow">Plantel 25-26</p>
				<h1>Roster completo con filtros y perfiles individuales.</h1>
				<p class="lead">
					Esta pantalla concentra la informacion que antes estaba comprimida en la home. Busca por
					nombre, filtra por posicion y recorre cada card con datos utiles para la entrega.
				</p>
			</div>
			<a class="back-link" href={baseUrl}>Volver al portal</a>
		</section>

		<section class="content-block">
			<PlayerGrid players={players} positions={positions} />
		</section>
	</main>
</Layout>

<style>
	.page {
		max-width: 1180px;
		margin: 0 auto;
		padding: 1.5rem 1.25rem 3rem;
		display: grid;
		gap: 1.5rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 1rem;
		align-items: end;
	}

	.eyebrow {
		margin: 0 0 0.35rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--brand);
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 3.8rem);
		line-height: 0.96;
		letter-spacing: -0.05em;
		max-width: 12ch;
	}

	.lead {
		max-width: 64ch;
		margin: 0.8rem 0 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.1rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--surface);
		font-weight: 700;
		box-shadow: var(--shadow-1);
	}

	.content-block {
		padding: 1.25rem;
		border-radius: 28px;
		background: color-mix(in srgb, var(--surface) 90%, transparent);
		border: 1px solid var(--border);
		box-shadow: var(--shadow-1);
	}

	@media (max-width: 720px) {
		.page {
			padding-inline: 1rem;
		}

		.hero {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}
</style>
