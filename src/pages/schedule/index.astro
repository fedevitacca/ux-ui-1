---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getBucksData } from '../../data/bucks';

const { schedule } = await getBucksData();
const baseUrl = import.meta.env.BASE_URL;
---

<Layout
	title="Milwaukee Bucks | Calendario"
	description="Vista dedicada a los proximos partidos de Milwaukee desde el 15 de marzo."
>
	<Navbar />
	<main class="page">
		<section class="hero">
			<div>
				<p class="eyebrow">Calendario</p>
				<h1>Proximos partidos desde el 15 de marzo.</h1>
				<p class="lead">
					En esta vista el calendario ya no compite con el roster. Cada juego tiene espacio propio para
					contexto, rival y locacion.
				</p>
			</div>
			<a class="back-link" href={baseUrl}>Volver al portal</a>
		</section>

		<section class="schedule-grid">
			{schedule.map((game) => (
				<article class="game-card">
					<p class="tiny">{game.date}</p>
					<h2>{game.rival}</h2>
					<p class="arena">{game.arena}</p>
					<p class="note">{game.note}</p>
				</article>
			))}
		</section>
	</main>
</Layout>

<style>
	.page {
		max-width: 1180px;
		margin: 0 auto;
		padding: 1.5rem 1.25rem 3rem;
		display: grid;
		gap: 1.5rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 1rem;
		align-items: end;
	}

	.eyebrow,
	.tiny {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--brand);
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 3.8rem);
		line-height: 0.96;
		letter-spacing: -0.05em;
		max-width: 12ch;
	}

	.lead {
		max-width: 62ch;
		margin: 0.8rem 0 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.1rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--surface);
		font-weight: 700;
		box-shadow: var(--shadow-1);
	}

	.schedule-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1rem;
	}

	.game-card {
		padding: 1.25rem;
		border-radius: 24px;
		background: linear-gradient(
			150deg,
			color-mix(in srgb, var(--surface) 92%, var(--brand) 8%),
			color-mix(in srgb, var(--surface) 82%, var(--brand-2) 18%)
		);
		border: 1px solid var(--border);
		box-shadow: var(--shadow-1);
	}

	.game-card h2 {
		margin: 0.3rem 0 0.4rem;
		font-size: 1.6rem;
		letter-spacing: -0.03em;
	}

	.arena {
		margin: 0;
		font-weight: 700;
		color: var(--ink);
	}

	.note {
		margin: 0.55rem 0 0;
	}

	@media (max-width: 720px) {
		.page {
			padding-inline: 1rem;
		}

		.hero {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}
</style>
