---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getBucksData } from '../../data/bucks';

const { stats } = await getBucksData();
const baseUrl = import.meta.env.BASE_URL;
---

<Layout
	title="Milwaukee Bucks | Snapshot"
	description="Resumen 25-26 de Milwaukee con indicadores y lectura rapida del momento."
>
	<Navbar />
	<main class="page">
		<section class="hero">
			<div>
				<p class="eyebrow">Snapshot</p>
				<h1>Radiografia del momento Bucks.</h1>
				<p class="lead">
					Esta vista esta pensada como una pantalla de resumen: cuatro indicadores fuertes, lectura de
					contexto y un tono mas editorial que tecnico.
				</p>
			</div>
			<a class="back-link" href={baseUrl}>Volver al portal</a>
		</section>

		<section class="stats-grid">
			{stats.map((item) => (
				<article class="stat-card">
					<p class="tiny">{item.label}</p>
					<strong>{item.value}</strong>
					{item.detail && <span>{item.detail}</span>}
				</article>
			))}
		</section>

		<section class="narrative">
			<article>
				<p class="tiny">Lectura</p>
				<h2>La temporada pide una narrativa mas directa.</h2>
				<p>
					La home abre como portal y esta pagina condensa el contexto. Sirve para presentar al usuario
					donde esta parado Milwaukee antes de entrar al roster o al calendario.
				</p>
			</article>
		</section>
	</main>
</Layout>

<style>
	.page {
		max-width: 1180px;
		margin: 0 auto;
		padding: 1.5rem 1.25rem 3rem;
		display: grid;
		gap: 1.5rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 1rem;
		align-items: end;
	}

	.eyebrow,
	.tiny {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--brand);
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 3.8rem);
		line-height: 0.96;
		letter-spacing: -0.05em;
		max-width: 11ch;
	}

	h2 {
		margin: 0.3rem 0 0.4rem;
		font-size: clamp(1.7rem, 3vw, 2.5rem);
		letter-spacing: -0.04em;
	}

	.lead {
		max-width: 60ch;
		margin: 0.8rem 0 0;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.1rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--surface);
		font-weight: 700;
		box-shadow: var(--shadow-1);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.stat-card,
	.narrative article {
		padding: 1.25rem;
		border-radius: 24px;
		border: 1px solid var(--border);
		background: var(--surface);
		box-shadow: var(--shadow-1);
	}

	.stat-card strong {
		display: block;
		margin-top: 0.35rem;
		font-size: 1.8rem;
		letter-spacing: -0.04em;
	}

	.stat-card span {
		display: block;
		margin-top: 0.35rem;
		color: var(--muted);
	}

	@media (max-width: 720px) {
		.page {
			padding-inline: 1rem;
		}

		.hero {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}
</style>
