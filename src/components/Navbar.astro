---
import ThemeToggle from './ThemeToggle.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<header class="site-header">
	<div class="inner">
		<a class="brand" href={baseUrl} aria-label="Volver al portal">
			<img class="brand__logo" src={`${baseUrl}milwaukee-bucks-1.svg`} alt="Milwaukee Bucks logo" />
			<span class="brand__text">
				Bucks <span class="sub">Catalog</span>
			</span>
		</a>

		<div class="actions">
			<a class="ghost" href={`${baseUrl}locker/`}>
				Locker
			</a>
			<a class="ghost" href="https://www.nba.com/bucks/tickets" target="_blank" rel="noreferrer">
				Tickets
			</a>
			<ThemeToggle />
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		backdrop-filter: blur(12px);
		background: color-mix(in srgb, var(--surface) 88%, transparent);
		border-bottom: 1px solid var(--border);
	}

	.inner {
		margin: 0 auto;
		max-width: 1180px;
		padding: 0.9rem 1.25rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		font-weight: 700;
		font-size: 1.05rem;
		letter-spacing: -0.01em;
		color: var(--brand);
		min-width: 0;
	}

	.brand__logo {
		width: 42px;
		height: 42px;
		display: block;
		object-fit: contain;
		filter: drop-shadow(0 8px 18px rgba(0, 71, 27, 0.18));
	}

	.brand__text .sub {
		display: inline-block;
		font-weight: 500;
		color: var(--brand-2);
	}

	.actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		justify-content: flex-end;
		flex-wrap: wrap;
	}

	.ghost {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.6rem 0.95rem;
		border-radius: 12px;
		border: 1px solid color-mix(in srgb, var(--brand-2) 18%, var(--border) 82%);
		color: var(--ink);
		font-weight: 700;
		background: color-mix(in srgb, var(--white) 82%, var(--cream) 18%);
		transition: border-color 150ms ease, transform 150ms ease, box-shadow 150ms ease;
		white-space: nowrap;
	}

	.ghost:hover {
		transform: translateY(-1px);
		border-color: color-mix(in srgb, var(--brand) 40%, var(--border) 60%);
		box-shadow: var(--shadow-1);
	}

	@media (max-width: 960px) {
		.inner {
			gap: 0.9rem;
		}
	}

	@media (max-width: 640px) {
		.inner {
			padding-inline: 1rem;
		}

		.brand__logo {
			width: 36px;
			height: 36px;
		}

		.brand__text .sub {
			display: none;
		}
	}

	@media (max-width: 460px) {
		.inner {
			align-items: flex-start;
		}

		.actions {
			width: 100%;
			justify-content: space-between;
		}

		.ghost {
			padding-inline: 0.8rem;
		}
	}
</style>
