---
export interface Props {
	id?: string;
	title: string;
	description?: string;
	eyebrow?: string;
	align?: 'start' | 'center';
}

const { id, title, description, eyebrow, align = 'start' } = Astro.props;
---

<section id={id} class={`section align-${align}`}>
	<header class="section__header">
		{eyebrow && <p class="eyebrow">{eyebrow}</p>}
		<div>
			<h2>{title}</h2>
			{description && <p class="section__description">{description}</p>}
		</div>
	</header>
	<div class="section__content">
		<slot />
	</div>
</section>

<style>
	.section {
		padding: clamp(2rem, 4vw, 3.5rem) 1.25rem;
		max-width: 1180px;
		margin: 0 auto;
	}

	.section__header {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		margin-bottom: 1.75rem;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.8rem;
		font-weight: 700;
		color: color-mix(in srgb, var(--brand) 70%, var(--muted) 30%);
		margin: 0;
	}

	h2 {
		font-size: clamp(1.6rem, 4vw, 2.15rem);
		margin: 0;
		letter-spacing: -0.02em;
	}

	.section__description {
		margin: 0;
		max-width: 720px;
	}

	.section__content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.align-center .section__header {
		text-align: center;
		align-items: center;
	}

	.align-center .section__description {
		max-width: 640px;
	}

	@media (max-width: 720px) {
		.section {
			padding-inline: 1rem;
		}
	}
</style>
