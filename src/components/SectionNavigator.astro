---
export interface NavItem {
	href: string;
	label: string;
	eyebrow: string;
	description: string;
	meta: string;
	accent?: 'green' | 'blue' | 'blue-alt' | 'black';
}

interface Props {
	items: NavItem[];
}

const { items }: Props = Astro.props;
---

<div class="portal-list">
	{items.map((item) => (
		<a class={`portal-card accent-${item.accent ?? 'green'}`} href={item.href} aria-label={`Ir a ${item.label}`}>
			<div class="portal-card__content">
				<p class="portal-card__eyebrow">{item.eyebrow}</p>
				<h2>{item.label}</h2>
				<p class="portal-card__description">{item.description}</p>
				<div class="portal-card__footer">
					<span>{item.meta}</span>
					<strong>Entrar</strong>
				</div>
			</div>
		</a>
	))}
</div>

<style>
	.portal-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		grid-template-rows: repeat(2, auto);
		gap: 0.9rem;
		padding: 0 1.25rem 1.25rem;
		max-width: 1120px;
		margin: 0 auto 1.5rem;
		width: 100%;
	}

	.portal-card {
		position: relative;
		min-height: 250px;
		aspect-ratio: 1.75 / 1;
		display: block;
		padding: clamp(1rem, 2vw, 1.25rem);
		border-radius: 24px;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--border) 72%, white 28%);
		box-shadow: var(--shadow-2);
		transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
	}

	.portal-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.18) 60%, rgba(0, 0, 0, 0.5) 100%),
			radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.16), transparent 28%);
	}

	.portal-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 36px 90px rgba(0, 0, 0, 0.2);
		border-color: color-mix(in srgb, white 25%, var(--brand) 75%);
	}

	.portal-card__content {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-rows: auto auto 1fr auto;
		gap: 0.45rem;
		height: 100%;
		max-width: 24ch;
		color: #f3f7f0;
	}

	.portal-card__eyebrow,
	.portal-card__footer span {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.78rem;
		font-weight: 700;
		opacity: 0.9;
	}

	h2 {
		margin: 0;
		font-size: clamp(1.35rem, 2vw, 2.15rem);
		line-height: 0.92;
		letter-spacing: -0.05em;
		max-width: 8ch;
	}

	.portal-card__description {
		margin: 0;
		max-width: 24ch;
		font-size: clamp(0.88rem, 0.9vw, 0.95rem);
		color: rgba(243, 247, 240, 0.92);
	}

	.portal-card__footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 0.4rem;
		margin-top: auto;
	}

	.portal-card__footer strong {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.62rem 0.88rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(14px);
		font-size: 0.9rem;
	}

	.accent-green {
		background:
			radial-gradient(circle at 82% 18%, rgba(121, 215, 165, 0.28), transparent 28%),
			linear-gradient(135deg, #052916 0%, #0d5b31 45%, #01190d 100%);
	}

	.accent-blue {
		background:
			radial-gradient(circle at 78% 20%, rgba(167, 203, 255, 0.22), transparent 26%),
			linear-gradient(135deg, #0b1833 0%, #274f96 46%, #081224 100%);
	}

	.accent-blue-alt {
		background:
			radial-gradient(circle at 78% 18%, rgba(125, 182, 255, 0.18), transparent 26%),
			linear-gradient(135deg, #14233e 0%, #1d428a 46%, #091120 100%);
	}

	.accent-black {
		background:
			radial-gradient(circle at 80% 16%, rgba(29, 66, 138, 0.18), transparent 24%),
			linear-gradient(135deg, #0d1014 0%, #1f2631 52%, #050607 100%);
	}

	@media (max-width: 560px) {
		.portal-list {
			grid-template-columns: 1fr;
			grid-template-rows: none;
		}

		.portal-card {
			min-height: 210px;
			aspect-ratio: auto;
		}
	}

	@media (max-width: 720px) {
		.portal-list {
			padding: 0 1rem 1rem;
			gap: 1rem;
		}

		.portal-card {
			border-radius: 26px;
		}

		h2 {
			max-width: none;
		}

		.portal-card__footer {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
